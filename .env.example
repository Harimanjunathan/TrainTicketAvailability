# ── Indian Rail API ───────────────────────────────────────────────────────────
# Free tier: 100 API hits/day. Register at https://indianrailapi.com/registration
# For hourly checks across all classes, a paid plan is recommended.
RAIL_API_KEY=your_key_here

# ── Gmail ─────────────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your account.
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Notification recipient ────────────────────────────────────────────────────
NOTIFY_EMAIL=harimanjunath@gmail.com

# ── Schedule (all times in IST) ───────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=60
DAILY_DIGEST_TIME=08:00
LOOKAHEAD_DAYS=14

# ── Alert thresholds (seats remaining) ────────────────────────────────────────
# Comma-separated. One alert fires per threshold per train/date/class per day.
# Example: alert when ≤60 seats left, alert again when ≤20 seats left.
ALERT_THRESHOLDS=60,20

# ── Departure window (24h HH:MM) ─────────────────────────────────────────────
# Trains with departure times outside this window are ignored.
CHENNAI_BLR_WINDOW_START=16:00
CHENNAI_BLR_WINDOW_END=22:00
BLR_CHENNAI_WINDOW_START=16:00
BLR_CHENNAI_WINDOW_END=22:00
